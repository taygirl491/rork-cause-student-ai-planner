{
  "expo": {
    "name": "Cause Planner",
    "slug": "cause-student-ai-planner",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/ios-light.png",
    "scheme": "causeai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/ios-light.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.minatoventures.causeai",
      "googleServicesFile": "./GoogleService-Info.plist",
      "entitlements": {
        "com.apple.developer.usernotifications.time-sensitive": true
      },
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow $(PRODUCT_NAME) to access your photos",
        "NSCameraUsageDescription": "Allow $(PRODUCT_NAME) to access your camera",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to access your microphone",
        "NSCalendarsUsageDescription": "This app uses your calendar to help you schedule and track task deadlines.",
        "NSLocationWhenInUseUsageDescription": "This app uses your location to help you find local study groups.",
        "ITSAppUsesNonExemptEncryption": false,
        "UISupportsDocumentBrowser": true,
        "LSSupportsOpeningDocumentsInPlace": true,
        "UIFileSharingEnabled": true
      },
      "usesIcloudStorage": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.minato.causeai",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.WAKE_LOCK",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "usesCleartextTraffic": true,
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/withModularHeaders",
      "./plugins/withAdiRegistration",
      "./plugins/withAndroidSoftInput",
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sound/alarm_clock_90867.wav"
          ]
        }
      ],
      "expo-alarm-module",
      "./plugins/withExcludeAlarmModuleIOS",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.minatoventures.causeai",
          "enableGooglePay": true
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "minato-tu"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "abiFilters": ["arm64-v8a"],
            "extraProguardRules": "-dontwarn com.stripe.android.pushProvisioning.**\n-keep class com.stripe.android.pushProvisioning.** { *; }"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://rork.com/"
      },
      "eas": {
        "projectId": "4f03b063-7906-41bc-bbe8-fb11613e296e"
      }
    },
    "owner": "uwaiz"
  }
}
