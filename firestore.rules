rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Tasks collection - users can only access their own tasks
    match /tasks/{taskId} {
      allow read, update, delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
    }
    
    // Classes collection - users can only access their own classes
    match /classes/{classId} {
      allow read, update, delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
    }
    
    // Notes collection - users can only access their own notes
    match /notes/{noteId} {
      allow read, update, delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
    }
    
    // Study Groups collection - members can read/update, creator can delete
    match /studyGroups/{groupId} {
      // Helper function to check if user is the creator
      function isCreator(creatorId) {
        return request.auth.uid == creatorId;
      }

      // Helper function to check if user is an admin of this group
      function isGroupAdmin() {
        return resource.data.admins.hasAny([request.auth.uid]);
      }

      // Allow reading groups (both list and get operations)
      allow read: if isAuthenticated();

      // Allow authenticated users to create groups
      allow create: if isAuthenticated() &&
        request.resource.data.creatorId == request.auth.uid;

      // Only the creator or a group admin can update group details
      allow update: if isAuthenticated() && (
        isCreator(resource.data.creatorId) || isGroupAdmin()
      );

      // Only creator can delete the group
      allow delete: if isAuthenticated() && isCreator(resource.data.creatorId);

      // Messages subcollection - only group admins and creator can read/write.
      // For full member access, add a flat 'memberIds' array to the group document
      // and check: get(...).data.memberIds.hasAny([request.auth.uid])
      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && (
          request.auth.uid == get(/databases/$(database)/documents/studyGroups/$(groupId)).data.creatorId ||
          get(/databases/$(database)/documents/studyGroups/$(groupId)).data.admins.hasAny([request.auth.uid])
        );
      }
    }

    // Users collection - users can update their own profile (e.g., pushToken)
    match /users/{userId} {
      allow read, update: if isOwner(userId);
      allow create: if isOwner(userId);
    }

    // Goals collection - users can only access their own goals
    match /goals/{goalId} {
      allow read, update, delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
    }

    // Content collection - Admin only write (requires admin custom claim), public read
    match /content/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
